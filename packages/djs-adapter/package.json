{
    "name": "@nodecord/djs-adapter",
    "version": "0.0.1-alpha.0",
    "type": "module",
    "types": "./dist/index.d.ts",
    "main": "./dist/index.js",
    "scripts": {
        "dev": "tsup --watch",
        "build": "tsup"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Datzu712/nodecord.git"
    },
    "author": "Datzu712",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "tsup": "latest",
        "typescript": "latest"
    },
    "dependencies": {
        "@nodecord/core": "workspace:*",
        "discord.js": "^14.26.3"
    },
    "peerDependencies": {
        "discord.js": "^14.0.0",
        "@nodecord/core": "workspace:*"
    }
}